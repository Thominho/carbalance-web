---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'cs' | 'en';
  activePage?: 'index' | 'about' | 'services' | 'contact';
  alwaysSolid?: boolean;
}

const { lang, activePage, alwaysSolid = false } = Astro.props;
const t = useTranslations(lang);

const prefix = lang === 'en' ? '/en' : '';
const links = [
  { href: `${prefix}/`, label: t('nav.home'), page: 'index' as const },
  { href: `${prefix}/about/`, label: t('nav.about'), page: 'about' as const },
  { href: `${prefix}/services/`, label: t('nav.services'), page: 'services' as const },
  { href: `${prefix}/contact/`, label: t('nav.contact'), page: 'contact' as const },
];

// Language switcher URLs: map current page to other lang
const pageSlugMap: Record<string, string> = {
  index: '/',
  about: '/about/',
  services: '/services/',
  contact: '/contact/',
};
const currentSlug = pageSlugMap[activePage ?? 'index'] ?? '/';
const czUrl = currentSlug;
const enUrl = `/en${currentSlug}`;
---

<nav id="navbar" class:list={[
  'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
  alwaysSolid && 'bg-primary/95 nav-blur shadow-lg'
]}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <a href={`${prefix}/`} class="flex items-center gap-3">
                <img src="/img/ttt.svg" alt="Car Balance" class="h-10" />
            </a>
            <div class="hidden md:flex items-center gap-8">
                {links.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            'text-sm font-medium hover:text-accent-light transition-colors',
                            activePage === link.page ? 'text-white' : 'text-white/70',
                        ]}
                    >
                        {link.label}
                    </a>
                ))}
                <div class="flex items-center bg-white/10 rounded-full p-0.5">
                    {lang === 'cs' ? (
                        <>
                            <span class="text-xs font-bold text-white bg-accent rounded-full px-3 py-1.5">CZ</span>
                            <a href={enUrl} class="text-xs font-bold text-white/50 hover:text-white rounded-full px-3 py-1.5 transition-colors">EN</a>
                        </>
                    ) : (
                        <>
                            <a href={czUrl} class="text-xs font-bold text-white/50 hover:text-white rounded-full px-3 py-1.5 transition-colors">CZ</a>
                            <span class="text-xs font-bold text-white bg-accent rounded-full px-3 py-1.5">EN</span>
                        </>
                    )}
                </div>
                <a href={`${prefix}/contact/`} class="inline-flex items-center gap-2 bg-transparent border border-white text-white text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-white/10 transition-all duration-300">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    {t('nav.call')}
                </a>
            </div>
            <button id="mobile-menu-btn" class="md:hidden text-white p-2" aria-label="Menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
        </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-primary/95 nav-blur border-t border-white/10">
        <div class="px-4 py-6 space-y-4">
            {links.map((link) => (
                <a
                    href={link.href}
                    class:list={[
                        'block font-medium py-2',
                        activePage === link.page ? 'text-white' : 'text-white/70',
                        link.page === 'contact' && activePage !== 'contact' && 'text-accent',
                    ]}
                >
                    {link.label}
                </a>
            ))}
            <div class="flex items-center gap-2 pt-2 border-t border-white/10 mt-2">
                {lang === 'cs' ? (
                    <>
                        <span class="text-xs font-bold text-white bg-accent rounded-full px-3 py-1.5">CZ</span>
                        <a href={enUrl} class="text-xs font-bold text-white/50 hover:text-white rounded-full px-3 py-1.5 bg-white/10 transition-colors">EN</a>
                    </>
                ) : (
                    <>
                        <a href={czUrl} class="text-xs font-bold text-white/50 hover:text-white rounded-full px-3 py-1.5 bg-white/10 transition-colors">CZ</a>
                        <span class="text-xs font-bold text-white bg-accent rounded-full px-3 py-1.5">EN</span>
                    </>
                )}
            </div>
        </div>
    </div>
</nav>

<script is:inline define:vars={{ alwaysSolid }}>
    const navbar = document.getElementById('navbar');
    if (!alwaysSolid) {
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                navbar.classList.add('bg-primary/95', 'nav-blur', 'shadow-lg');
            } else {
                navbar.classList.remove('bg-primary/95', 'nav-blur', 'shadow-lg');
            }
        });
    }
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
    });
</script>
