---
interface Props {
  id: string;
  number: string;
  title: string;
  description: string;
  features: string[];
  image: string;
  ctaText: string;
  ctaHref: string;
  reverse: boolean;
}

const { id, number, title, description, features, image, ctaText, ctaHref, reverse } = Astro.props;
---

<div id={id} class="grid lg:grid-cols-2 gap-16 items-center scroll-mt-24">
  <div class={reverse ? 'order-2 lg:order-1' : ''}>
    {reverse ? (
      <img src={image} alt={title} class="rounded-2xl shadow-2xl w-full" />
    ) : (
      <Fragment>
        <div class="inline-flex items-center gap-2 bg-accent/10 rounded-full px-4 py-1.5 mb-6">
          <span class="text-accent text-sm font-semibold">{number}</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-primary mb-6">{title}</h2>
        <p class="text-muted leading-relaxed mb-6">{description}</p>
        <ul class="space-y-3">
          {features.map((feature) => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-muted">{feature}</span>
            </li>
          ))}
        </ul>
        <a href={ctaHref} class="btn-primary mt-8">{ctaText}</a>
      </Fragment>
    )}
  </div>
  <div class={reverse ? 'order-1 lg:order-2' : ''}>
    {reverse ? (
      <Fragment>
        <div class="inline-flex items-center gap-2 bg-accent/10 rounded-full px-4 py-1.5 mb-6">
          <span class="text-accent text-sm font-semibold">{number}</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-primary mb-6">{title}</h2>
        <p class="text-muted leading-relaxed mb-6">{description}</p>
        <ul class="space-y-3">
          {features.map((feature) => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="text-muted">{feature}</span>
            </li>
          ))}
        </ul>
        <a href={ctaHref} class="btn-primary mt-8">{ctaText}</a>
      </Fragment>
    ) : (
      <img src={image} alt={title} class="rounded-2xl shadow-2xl w-full" />
    )}
  </div>
</div>
