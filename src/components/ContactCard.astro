---
interface Props {
  title: string;
  icon: 'phone' | 'email' | 'location';
  content: string;
  href?: string;
  detail?: string;
}

const { title, icon, content, href, detail } = Astro.props;

const icons = {
  phone: '<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>',
  email: '<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
  location: '<svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
};
---

<div class="card-hover bg-surface rounded-2xl p-6 lg:p-8 border border-gray-100 mb-6">
  <h3 class="text-xl font-bold text-primary mb-4">{title}</h3>
  {icon === 'location' ? (
    <div class="flex items-start gap-3 text-muted">
      <Fragment set:html={icons[icon]} />
      <div>
        {detail && <p class="font-semibold text-primary">{detail}</p>}
        <Fragment set:html={content} />
      </div>
    </div>
  ) : (
    <a href={href} class="flex items-center gap-3 text-muted hover:text-accent transition-colors text-lg">
      <Fragment set:html={icons[icon]} />
      {content}
    </a>
  )}
</div>
