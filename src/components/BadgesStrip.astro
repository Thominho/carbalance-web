---
interface Props {
  badges: Array<{ value: string; label: string }>;
}

const { badges } = Astro.props;
---

<section class="bg-primary py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8">
      {badges.map((badge) => (
        <div class="text-center p-5 bg-white/5 rounded-2xl">
          <div class="text-2xl font-extrabold text-white mb-1">{badge.value}</div>
          <div class="text-white/50 text-xs">{badge.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
