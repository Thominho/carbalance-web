---
interface Props {
  url: string;
}

const { url } = Astro.props;
---

<div class="rounded-2xl overflow-hidden mb-8 border border-gray-100">
  <iframe
    src={url}
    width="100%"
    height="350"
    style="border:0;"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    class="w-full"
  ></iframe>
</div>
